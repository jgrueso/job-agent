# ── LLM APIs ──────────────────────────────────────────────────────────────────
# Anthropic Claude (primary) — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq (free fallback) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Create a bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal chat ID (send /myid to the bot after starting it)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Web App (TWA) ──────────────────────────────────────────────────────────────
# Public HTTPS URL for the Telegram Web App
# Use cloudflared: cloudflared tunnel --url http://localhost:8080
WEBAPP_URL=https://your-tunnel.trycloudflare.com
WEBAPP_PORT=8080

# ── Pipeline Settings ─────────────────────────────────────────────────────────
# How often (hours) to search for new jobs
SEARCH_INTERVAL_HOURS=6
# Minimum AI match score (0-100) to notify. Lower = more noise.
MIN_MATCH_SCORE=65
# UTC hour for the daily summary message (23 = 6 PM Colombia)
DAILY_SUMMARY_HOUR_UTC=23
